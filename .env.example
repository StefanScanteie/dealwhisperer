# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Vivun — app.vivun.com → Settings → API Keys
VIVUN_API_KEY=your-vivun-api-key
VIVUN_BASE_URL=https://api.vivun.com/v1

# Taegis XDR API — same credentials as Taegis Magic (docs: https://docs.taegis.secureworks.com/magic/magic_overview/)
# Create in Taegis XDR portal → Settings → API Credentials
TAEGIS_CLIENT_ID=your-taegis-client-id
TAEGIS_CLIENT_SECRET=your-taegis-client-secret
TAEGIS_BASE_URL=https://api.taegis.secureworks.com

# Serper OSINT (optional) — serper.dev — free tier: 2500 searches/month
SERPER_API_KEY=your-serper-key

# App settings
PORT=5001
SE_NAME=Your Name
